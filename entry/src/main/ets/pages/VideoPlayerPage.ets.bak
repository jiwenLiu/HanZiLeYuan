import { router } from '@kit.ArkUI'
import { window } from '@kit.ArkUI'
import { preferences } from '@kit.ArkData'
import { common } from '@kit.AbilityKit'

interface VideoInfo {
  id: string
  title: string
  subtitle: string
  emoji: string
  duration: string
}

interface VideoProgress {
  videoId: string
  progress: number
  status: string
  lastPlayTime: number
  currentTime: number
  totalTime: number
}

@Entry
@Component
struct VideoPlayerPage {
  @State currentVideoIndex: number = 0
  @State isPlaying: boolean = false
  @State videoSrc: string = ''
  @State currentTime: number = 0
  @State totalTime: number = 0
  @State progress: number = 0
  @State videoStatus: string = 'not_started'
  @State stars: number = 0
  
  // жҺ§еҲ¶ж ҸжҳҫзӨәзҠ¶жҖҒ
  @State showControls: boolean = true
  private hideControlsTimer: number = -1
  private autoHideDelay: number = 3000
  
  private videoController: VideoController = new VideoController()
  private progressUpdateTimer: number = -1
  private dataPreferences: preferences.Preferences | null = null

  // 29дёӘи§Ҷйў‘еҲ—иЎЁпјҲжҜҸдёӘеҲҶзұ»жңҖеӨҡ4дёӘпјү
  private videoList: VideoInfo[] = [
    // еҠЁзү©зҜҮ (4дёӘ)
    { id: '1', title: 'з¬¬1иҜҫ', subtitle: 'гҖҠй©¬зүӣзҫҠгҖӢ', emoji: 'рҹҗҙ', duration: '15:32' },
    { id: '2', title: 'з¬¬2иҜҫ', subtitle: 'гҖҠйёЎзӢ—зҢӘзҢ«гҖӢ', emoji: 'рҹҗ•', duration: '14:10' },
    { id: '3', title: 'з¬¬3иҜҫ', subtitle: 'гҖҠйёҹйұјиҷ«дёҮгҖӢ', emoji: 'рҹҗҰ', duration: '14:25' },
    { id: '4', title: 'з¬¬4иҜҫ', subtitle: 'гҖҠзҫҪйЈһд№ зҝ”гҖӢ', emoji: 'рҹҰ…', duration: '13:50' },
    // жӨҚзү©зҜҮ (3дёӘ)
    { id: '5', title: 'з¬¬5иҜҫ', subtitle: 'гҖҠжңЁжһ—жЈ®жң¬жң«зүҮгҖӢ', emoji: 'рҹҢі', duration: '15:20' },
    { id: '6', title: 'з¬¬6иҜҫ', subtitle: 'гҖҠж ‘жЎ‘жЎғжқҫжҹігҖӢ', emoji: 'рҹҢІ', duration: '14:35' },
    { id: '7', title: 'з¬¬7иҜҫ', subtitle: 'гҖҠзұійәҰиҸңжһңз“ңгҖӢ', emoji: 'пҝҪ', uduration: '14:15' },
    // иҮӘз„¶зҜҮ (3дёӘ)
    { id: '8', title: 'з¬¬8иҜҫ', subtitle: 'гҖҠж°ҙжіүе·қе·һжҙІгҖӢ', emoji: 'рҹ’§', duration: '14:10' },
    { id: '9', title: 'з¬¬9иҜҫ', subtitle: 'гҖҠжІіжұҹж№–жө·гҖӢ', emoji: 'пҝҪ', du ration: '13:45' },
    { id: '10', title: 'з¬¬10иҜҫ', subtitle: 'гҖҠеҺӮзҹіеҺҹжәҗгҖӢ', emoji: 'пҝҪ',  duration: '14:20' },
    // еӨ©ж–Үж°”иұЎзҜҮ (4дёӘ)
    { id: '14', title: 'з¬¬14иҜҫ', subtitle: 'гҖҠж—ҘжңҲжҷ¶жҳҹгҖӢ', emoji: 'вҳҖпёҸ', duration: '14:30' },
    { id: '15', title: 'з¬¬15иҜҫ', subtitle: 'гҖҠж—¶ж—©жҷҡгҖӢ', emoji: 'вҸ°', duration: '13:40' },
    { id: '16', title: 'з¬¬16иҜҫ', subtitle: 'гҖҠйӣЁдә‘йӣӘгҖӢ', emoji: 'пҝҪпёҸ',  duration: '14:00' },
    { id: '17', title: 'з¬¬17иҜҫ', subtitle: 'гҖҠжҳҘеӨҸз§ӢеҶ¬гҖӢ', emoji: 'пҝҪ'', duration: '14:25' },
    // йўңиүІж–№дҪҚзҜҮ (3дёӘ)
    { id: '18', title: 'з¬¬18иҜҫ', subtitle: 'гҖҠи“қйқ’зәўй»‘зҷҪгҖӢ', emoji: 'рҹҺЁ', duration: '13:50' },
    { id: '19', title: 'з¬¬19иҜҫ', subtitle: 'гҖҠдёҠдёӢеҶ…еӨ–гҖӢ', emoji: 'вҶ•пёҸ', duration: '13:35' },
    { id: '20', title: 'з¬¬20иҜҫ', subtitle: 'гҖҠдёңиҘҝеҚ—еҢ—дёӯгҖӢ', emoji: 'рҹ§ӯ', duration: '14:10' },
    // е…үдёҺзҒ«зҜҮ (2дёӘ)
    { id: '21', title: 'з¬¬21иҜҫ', subtitle: 'гҖҠзҒ«зӮҺзҒ°иөӨзҮғзҒҜгҖӢ', emoji: 'пҝҪ', durвҖҚation: '14:45' },
    { id: '22', title: 'з¬¬22иҜҫ', subtitle: 'гҖҠе…үжҳҺдә®зҡ„й—ӘгҖӢ', emoji: 'рҹ’Ў', duration: '13:55' },
    // дәәзү©зҜҮ (4дёӘ)
    { id: '23', title: 'з¬¬23иҜҫ', subtitle: 'гҖҠдәәд»Һдј—жҜ”еҢ—гҖӢ', emoji: 'пҝҪ', durration: '14:30' },
    { id: '24', title: 'з¬¬24иҜҫ', subtitle: 'гҖҠеӨ§еӨӘз«Ӣз«ҷдәӨж–ҮзҫҺгҖӢ', emoji: 'рҹ‘ЁвҖҚрҹ‘©вҖҚрҹ‘§вҖҚрҹ‘Ұ', duration: '13:40' },
    { id: '25', title: 'з¬¬25иҜҫ', subtitle: 'гҖҠдҝқеӯҷе„ҝеӯ©гҖӢ', emoji: 'пҝҪ',' duration: '14:00' },
    { id: '26', title: 'з¬¬26иҜҫ', subtitle: 'гҖҠеҘіеҘҪжҜҚжҜҸеҰҮе®үгҖӢ', emoji: 'пҝҪ' , duration: '14:20' },
    // иә«дҪ“зҜҮ (4дёӘ)
    { id: '29', title: 'з¬¬29иҜҫ', subtitle: 'гҖҠеӨ©е…ғйҰ–йЎөеӨҙеҸ‘гҖӢ', emoji: 'пҝҪ', durtation: '13:45' },
    { id: '32', title: 'з¬¬32иҜҫ', subtitle: 'гҖҠеҸЈиҲҢйҪҝзүҷз©ҝгҖӢ', emoji: 'пҝҪ', duuration: '14:10' },
    // ж—Ҙеёёз”ҹжҙ»зҜҮ (4дёӘ)
    { id: '40', title: 'з¬¬40иҜҫ', subtitle: 'гҖҠе®«е Ӯе®ӨжҲҝе®¶гҖӢ', emoji: 'рҹҸ ', duration: '14:10' },
    { id: '41', title: 'з¬¬41иҜҫ', subtitle: 'гҖҠиҪҰиҫҮиҲҹиҲ№гҖӢ', emoji: 'рҹҡ—', duration: '13:30' },
    { id: '42', title: 'з¬¬42иҜҫ', subtitle: 'гҖҠиЎҢйҒ“иЎ—еёӮгҖӢ', emoji: 'пҝҪпёҸ',  duration: '14:05' },
    { id: '43', title: 'з¬¬43иҜҫ', subtitle: 'гҖҠиЎЈиЈҳиЎЁйҮҢиў«гҖӢ', emoji: 'рҹ‘”', duration: '14:15' }
  ]

  async aboutToAppear() {
    console.info('рҹҺ¬ и§Ҷйў‘ж’ӯж”ҫйЎөйқўеҠ иҪҪ')
    await this.initDataPreferences()
    await this.setFullScreen()

    const params = router.getParams() as Record<string, Object>
    if (params && params['courseId']) {
      const courseId = params['courseId'] as string
      console.info(`жҺҘж”¶еҲ°courseId: ${courseId}`)
      const index = this.getCourseIndex(courseId)
      if (index !== -1) {
        this.currentVideoIndex = index
        console.info(`вң… и®ҫзҪ®и§Ҷйў‘зҙўеј•: ${index}`)
      }
    }

    this.loadVideo()
    await this.loadVideoProgress()
    this.startProgressUpdate()
    this.startAutoHideTimer()
  }

  async aboutToDisappear() {
    await this.saveVideoProgress()
    if (this.progressUpdateTimer !== -1) {
      clearInterval(this.progressUpdateTimer)
    }
    if (this.hideControlsTimer !== -1) {
      clearTimeout(this.hideControlsTimer)
    }
  }

  // зӮ№еҮ»еұҸе№•пјҡжҡӮеҒң/ж’ӯж”ҫпјҢе№¶жҳҫзӨәжҺ§еҲ¶ж Ҹ
  handleScreenTap() {
    // жҳҫзӨәжҺ§еҲ¶ж Ҹ
    this.showControls = true
    
    // еҲҮжҚўж’ӯж”ҫ/жҡӮеҒң
    if (this.isPlaying) {
      this.videoController.pause()
      // жҡӮеҒңж—¶дёҚиҮӘеҠЁйҡҗи—ҸжҺ§еҲ¶ж Ҹ
    } else {
      this.videoController.start()
      // ж’ӯж”ҫж—¶еҗҜеҠЁиҮӘеҠЁйҡҗи—Ҹ
      this.startAutoHideTimer()
    }
  }

  // еҗҜеҠЁиҮӘеҠЁйҡҗи—Ҹе®ҡж—¶еҷЁ
  startAutoHideTimer() {
    if (this.hideControlsTimer !== -1) {
      clearTimeout(this.hideControlsTimer)
    }
    this.hideControlsTimer = setTimeout(() => {
      if (this.isPlaying) {
        this.showControls = false
      }
    }, this.autoHideDelay)
  }

  async initDataPreferences() {
    try {
      const context = getContext(this) as common.UIAbilityContext
      this.dataPreferences = await preferences.getPreferences(context, 'video_progress')
      console.info('вң… ж•°жҚ®еӯҳеӮЁеҲқе§ӢеҢ–жҲҗеҠҹ')
    } catch (err) {
      console.error('вқҢ ж•°жҚ®еӯҳеӮЁеҲқе§ӢеҢ–еӨұиҙҘ:', JSON.stringify(err))
    }
  }

  async setFullScreen() {
    try {
      const windowStage = (getContext(this) as common.UIAbilityContext).windowStage
      const mainWindow = await windowStage.getMainWindow()
      await mainWindow.setWindowLayoutFullScreen(true)
      await mainWindow.setWindowSystemBarEnable([])
      console.info('вң… VideoPlayerPage е…ЁеұҸжЁЎејҸе·ІеҗҜз”Ё')
    } catch (err) {
      console.error('вқҢ VideoPlayerPage и®ҫзҪ®е…ЁеұҸеӨұиҙҘ:', JSON.stringify(err))
    }
  }

  async loadVideoProgress() {
    if (!this.dataPreferences) return
    try {
      const videoId = this.videoList[this.currentVideoIndex].id
      const key = `video_progress_${videoId}`
      const value = await this.dataPreferences.get(key, '')
      if (value) {
        const progressData: VideoProgress = JSON.parse(value as string)
        this.progress = progressData.progress
        this.videoStatus = progressData.status
        this.currentTime = progressData.currentTime
        this.totalTime = progressData.totalTime
        this.updateStars()
        console.info(`рҹ“– еҠ иҪҪиҝӣеәҰ: ${this.progress}%, зҠ¶жҖҒ: ${this.videoStatus}`)
      }
    } catch (err) {
      console.error('вқҢ еҠ иҪҪиҝӣеәҰеӨұиҙҘ:', JSON.stringify(err))
    }
  }

  async saveVideoProgress() {
    if (!this.dataPreferences) return
    try {
      const videoId = this.videoList[this.currentVideoIndex].id
      const key = `video_progress_${videoId}`
      const progressData: VideoProgress = {
        videoId: videoId,
        progress: this.progress,
        status: this.videoStatus,
        lastPlayTime: Date.now(),
        currentTime: this.currentTime,
        totalTime: this.totalTime
      }
      await this.dataPreferences.put(key, JSON.stringify(progressData))
      await this.dataPreferences.flush()
      console.info(`рҹ’ҫ дҝқеӯҳиҝӣеәҰ: ${this.progress}%, зҠ¶жҖҒ: ${this.videoStatus}`)
    } catch (err) {
      console.error('вқҢ дҝқеӯҳиҝӣеәҰеӨұиҙҘ:', JSON.stringify(err))
    }
  }

  startProgressUpdate() {
    this.progressUpdateTimer = setInterval(() => {
      if (this.isPlaying && this.totalTime > 0) {
        this.progress = Math.floor((this.currentTime / this.totalTime) * 100)
        this.updateStatusAndStars()
      }
    }, 1000)
  }

  updateStatusAndStars() {
    if (this.progress === 0) {
      this.videoStatus = 'not_started'
      this.stars = 0
    } else if (this.progress < 50) {
      this.videoStatus = 'learning'
      this.stars = 1
    } else if (this.progress < 100) {
      this.videoStatus = 'learning'
      this.stars = 2
    } else {
      this.videoStatus = 'completed'
      this.stars = 3
    }
  }

  updateStars() {
    if (this.progress === 0) {
      this.stars = 0
    } else if (this.progress < 50) {
      this.stars = 1
    } else if (this.progress < 100) {
      this.stars = 2
    } else {
      this.stars = 3
    }
  }

  formatTime(seconds: number): string {
    const mins = Math.floor(seconds / 60)
    const secs = Math.floor(seconds % 60)
    return `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`
  }

  async playPrevious() {
    if (this.currentVideoIndex > 0) {
      console.info('рҹ”ҷ еҲҮжҚўеҲ°дёҠдёҖдёӘи§Ҷйў‘')
      await this.saveVideoProgress()
      this.currentVideoIndex--
      this.loadVideo()
      await this.loadVideoProgress()
      this.isPlaying = false
      this.progress = 0
      setTimeout(() => {
        this.videoController.start()
      }, 500)
      this.startAutoHideTimer()
    }
  }

  async playNext() {
    if (this.currentVideoIndex < this.videoList.length - 1) {
      console.info('рҹ”ң еҲҮжҚўеҲ°дёӢдёҖдёӘи§Ҷйў‘')
      await this.saveVideoProgress()
      this.currentVideoIndex++
      this.loadVideo()
      await this.loadVideoProgress()
      this.isPlaying = false
      this.progress = 0
      setTimeout(() => {
        this.videoController.start()
      }, 500)
      this.startAutoHideTimer()
    }
  }

  loadVideo() {
    const video = this.videoList[this.currentVideoIndex]
    this.videoSrc = `videos/з¬¬${video.id}иҜҫ${video.subtitle}.mp4`
    console.info(`рҹ“№ еҠ иҪҪи§Ҷйў‘: ${this.videoSrc}`)
  }

  getCourseIndex(courseId: string): number {
    const index = this.videoList.findIndex(video => video.id === courseId)
    return index
  }

  build() {
    Stack() {
      // й»‘иүІиғҢжҷҜ
      Column()
        .width('100%')
        .height('100%')
        .backgroundColor('#000000')

      // и§Ҷйў‘ж’ӯж”ҫеҷЁпјҲе…ЁеұҸпјҢйҡҗи—Ҹзі»з»ҹжҺ§еҲ¶ж Ҹпјү
      Video({
        src: $rawfile(this.videoSrc),
        controller: this.videoController
      })
        .width('100%')
        .height('100%')
        .controls(false) // йҡҗи—Ҹзі»з»ҹжҺ§еҲ¶ж ҸпјҲеҢ…жӢ¬е…ЁеұҸжҢүй’®пјү
        .autoPlay(true)
        .objectFit(ImageFit.Cover) // дҪҝз”ЁCoverеЎ«ж»ЎеұҸе№•пјҢж— й»‘иҫ№
        .backgroundColor('#000000')
        .onStart(() => {
          console.info('в–¶пёҸ и§Ҷйў‘ејҖе§Ӣж’ӯж”ҫ')
          this.isPlaying = true
          this.startAutoHideTimer()
        })
        .onPause(() => {
          console.info('вҸёпёҸ и§Ҷйў‘жҡӮеҒң')
          this.isPlaying = false
          this.showControls = true
        })
        .onFinish(() => {
          console.info('рҹҸҒ и§Ҷйў‘ж’ӯж”ҫе®ҢжҲҗ')
          this.isPlaying = false
          this.progress = 100
          this.videoStatus = 'completed'
          this.stars = 3
          this.saveVideoProgress()
          this.showControls = true
          
          if (this.currentVideoIndex < this.videoList.length - 1) {
            setTimeout(() => {
              this.playNext()
            }, 1000)
          }
        })
        .onError(() => {
          console.error('вқҢ и§Ҷйў‘ж’ӯж”ҫй”ҷиҜҜ')
          this.showControls = true
        })
        .onUpdate((event) => {
          if (event && event.time !== undefined) {
            this.currentTime = event.time
          }
        })
        .onPrepared((event) => {
          if (event && event.duration !== undefined) {
            this.totalTime = event.duration
          }
        })

      // ж’ӯж”ҫ/жҡӮеҒңеӣҫж ҮпјҲеұҸе№•дёӯеӨ®пјҢд»…еңЁжҡӮеҒңж—¶жҳҫзӨәпјү
      if (!this.isPlaying) {
        Column() {
          Text('в–¶')
            .fontSize(80)
            .fontColor('rgba(255, 255, 255, 0.9)')
            .textShadow({ radius: 20, color: 'rgba(0,0,0,0.5)' })
        }
        .width(120)
        .height(120)
        .borderRadius(60)
        .backgroundColor('rgba(0, 0, 0, 0.6)')
        .justifyContent(FlexAlign.Center)
        .alignItems(HorizontalAlign.Center)
        .position({ x: '50%', y: '50%' })
        .translate({ x: '-50%', y: '-50%' })
        .zIndex(15)
        .onClick(() => {
          this.videoController.start()
        })
      }

      // зӮ№еҮ»еҢәеҹҹпјҲз”ЁдәҺжҡӮеҒңпјү
      if (this.isPlaying) {
        Column()
          .width('100%')
          .height('100%')
          .onClick(() => {
            this.handleScreenTap()
          })
      }

      // йЎ¶йғЁжҺ§еҲ¶ж Ҹ
      if (this.showControls) {
        Row() {
          // иҝ”еӣһжҢүй’®пјҲеңҶеҪўеӣҫж Үпјү
          Stack() {
            Column()
              .width(50)
              .height(50)
              .borderRadius(25)
              .backgroundColor('rgba(0, 0, 0, 0.6)')

            Text('вҶҗ')
              .fontSize(28)
              .fontColor(Color.White)
              .fontWeight(FontWeight.Bold)
          }
          .onClick(() => {
            router.back()
          })

          Blank()

          // и§Ҷйў‘ж Үйўҳ
          Column() {
            Text(`${this.videoList[this.currentVideoIndex].title}`)
              .fontSize(18)
              .fontColor(Color.White)
              .fontWeight(FontWeight.Bold)
              .textShadow({ radius: 4, color: 'rgba(0,0,0,0.8)' })
            
            Text(`${this.videoList[this.currentVideoIndex].subtitle}`)
              .fontSize(14)
              .fontColor('rgba(255,255,255,0.8)')
              .textShadow({ radius: 4, color: 'rgba(0,0,0,0.8)' })
          }

          Blank()

          // и§Ҷйў‘еәҸеҸ·
          Text(`${this.currentVideoIndex + 1}/${this.videoList.length}`)
            .fontSize(14)
            .fontColor(Color.White)
            .padding({ left: 12, right: 12, top: 6, bottom: 6 })
            .backgroundColor('rgba(0, 0, 0, 0.5)')
            .borderRadius(12)
        }
        .width('100%')
        .padding({ left: 20, right: 20, top: 16, bottom: 16 })
        .linearGradient({
          angle: 180,
          colors: [['rgba(0,0,0,0.7)', 0], ['rgba(0,0,0,0)', 1]]
        })
        .position({ x: 0, y: 0 })
        .zIndex(20)
      }

      // еә•йғЁжҺ§еҲ¶ж ҸпјҲеҸӘжңүдёҠдёҖдёӘ/дёӢдёҖдёӘеӣҫж Үпјү
      if (this.showControls) {
        Row() {
          // дёҠдёҖдёӘеӣҫж Ү
          Stack() {
            Column()
              .width(56)
              .height(56)
              .borderRadius(28)
              .backgroundColor(this.currentVideoIndex > 0 ? 'rgba(0, 0, 0, 0.6)' : 'rgba(0, 0, 0, 0.3)')

            Text('вҸ®')
              .fontSize(28)
              .fontColor(this.currentVideoIndex > 0 ? Color.White : 'rgba(255,255,255,0.4)')
          }
          .onClick(() => {
            if (this.currentVideoIndex > 0) {
              this.playPrevious()
            }
          })

          Blank()

          // иҝӣеәҰжҳҫзӨә
          Column({ space: 4 }) {
            // иҝӣеәҰжқЎ
            Row() {
              Row()
                .width(`${this.totalTime > 0 ? (this.currentTime / this.totalTime) * 100 : 0}%`)
                .height('100%')
                .backgroundColor('#fbbf24')
                .borderRadius(3)
            }
            .width(200)
            .height(6)
            .backgroundColor('rgba(255,255,255,0.3)')
            .borderRadius(3)

            // ж—¶й—ҙжҳҫзӨә
            Text(`${this.formatTime(this.currentTime)} / ${this.formatTime(this.totalTime)}`)
              .fontSize(12)
              .fontColor('rgba(255,255,255,0.9)')
          }

          Blank()

          // дёӢдёҖдёӘеӣҫж Ү
          Stack() {
            Column()
              .width(56)
              .height(56)
              .borderRadius(28)
              .backgroundColor(this.currentVideoIndex < this.videoList.length - 1 ? 'rgba(0, 0, 0, 0.6)' : 'rgba(0, 0, 0, 0.3)')

            Text('вҸӯ')
              .fontSize(28)
              .fontColor(this.currentVideoIndex < this.videoList.length - 1 ? Color.White : 'rgba(255,255,255,0.4)')
          }
          .onClick(() => {
            if (this.currentVideoIndex < this.videoList.length - 1) {
              this.playNext()
            }
          })
        }
        .width('100%')
        .padding({ left: 24, right: 24, top: 16, bottom: 40 })
        .linearGradient({
          angle: 0,
          colors: [['rgba(0,0,0,0.7)', 0], ['rgba(0,0,0,0)', 1]]
        })
        .position({ x: 0, y: '100%' })
        .translate({ x: 0, y: '-100%' })
        .zIndex(20)
      }
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#000000')
  }
}
